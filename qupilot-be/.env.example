PORT=3000

# Supabase (service role key — server-only, never expose to client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Solana RPC for tx verification
SOLANA_RPC_URL=https://api.devnet.solana.com

# Treasury keypair (base58-encoded secret key) used to send reward transfers on claim
TREASURY_SECRET_KEY=

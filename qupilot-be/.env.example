PORT=3000

# Supabase (service role key — server-only, never expose to client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# EVM RPC for tx verification
EVM_RPC_URL=https://rpc.sepolia.mantle.xyz

# Treasury signer (private key hex 64 chars, optional 0x) used to send reward transfers on claim
TREASURY_PRIVATE_KEY=
